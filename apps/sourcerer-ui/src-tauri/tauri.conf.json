{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sourcerer",
  "version": "0.19.84",
  "identifier": "io.mikeweaver.sourcerer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Sourcerer",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "backgroundColor": "#0E1116"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "One search. Every source. Every OS.",
    "longDescription": "Sourcerer is a cross-platform realtime filesystem search engine — filename, content, audio, and similarity lenses on one journal-fed index.",
    "copyright": "Copyright © 2026 Mike Weaver.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "wix": {},
      "nsis": {}
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {},
      "rpm": {},
      "appimage": {}
    }
  }
}
