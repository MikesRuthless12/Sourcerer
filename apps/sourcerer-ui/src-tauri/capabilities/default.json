{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Phase 11 capability set: clipboard, dialogs, fs reads, global hotkey, OS info, shell open.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "dialog:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "global-shortcut:default",
    "opener:default",
    "os:default"
  ]
}
